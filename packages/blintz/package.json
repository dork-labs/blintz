{
  "name": "blintz",
  "version": "0.2.0",
  "type": "module",
  "description": "Blintz — a Vue-free React port of Milkdown's Crepe editor: the polished WYSIWYG markdown UX (slash menu, block drag handle, selection toolbar, rich node views) rebuilt as React components, with clean markdown round-tripping.",
  "keywords": [
    "markdown",
    "markdown-editor",
    "wysiwyg",
    "editor",
    "react",
    "milkdown",
    "crepe",
    "prosemirror",
    "remark"
  ],
  "license": "MIT",
  "author": "Dork Labs",
  "homepage": "https://github.com/dork-labs/blintz#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dork-labs/blintz.git",
    "directory": "packages/blintz"
  },
  "bugs": {
    "url": "https://github.com/dork-labs/blintz/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/blintz.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "ATTRIBUTION.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@floating-ui/dom": "^1.7.6",
    "@milkdown/kit": "^7.21.2",
    "@milkdown/react": "^7.21.2",
    "@milkdown/theme-nord": "^7.21.2",
    "@prosemirror-adapter/react": "0.5.3",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.11",
    "katex": "^0.17.0",
    "lucide-static": "^1.21.0",
    "prosemirror-virtual-cursor": "^0.4.2",
    "remark-frontmatter": "^5.0.0",
    "remark-math": "^6.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.5.4"
  }
}
