    "@milkdown/kit": "^7.21.2",
    "@milkdown/react": "^7.21.2",
    "@milkdown/theme-nord": "^7.21.2",
    "@prosemirror-adapter/react": "0.5.3",
    "@uiw/react-md-editor": "4.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
